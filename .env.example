# ======================================
# iLabs1 (SGB Operations Simulator) — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# ======================================

# --- Database ---
# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?ssl=true&replicaSet=...

# --- Auth ---
# JWT signing secret — use a strong, random string (required, no fallback)
JWT_SECRET=replace_with_a_strong_random_string

# --- AI Provider Keys ---
# Google Gemini (primary LLM)
GEMINI_API_KEY=your_gemini_api_key

# Cerebras (secondary LLM fallback)
CEREBRAS_API_KEY=your_cerebras_api_key

# Groq (tertiary — optional, currently unused)
# GROQ_API_KEY=your_groq_api_key

# OpenRouter (used for scoring engine email evaluation)
OPENROUTER_API_KEY=your_openrouter_api_key

# --- Server ---
# Backend port (optional, default: 3002)
PORT=3002

# --- CORS / Socket.io ---
# Comma-separated list of allowed frontend origins for Socket.io CORS
# Defaults to http://localhost:3000 in development
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend (set in /frontend/.env.local) ---
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
